{
  "name": "browser-extension-capabilities",
  "description": "Zero-dependency library for analyzing browser extension capabilities from manifest files",
  "packageManager": "pnpm@9.9.0",
  "version": "2.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "browser-extension",
    "manifest",
    "capabilities",
    "analysis",
    "chrome-extension",
    "firefox-extension",
    "edge-extension",
    "webextension",
    "typescript",
    "zero-dependency"
  ],
  "author": "Cezar Augusto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cezaraugusto/browser-extension-capabilities.git"
  },
  "bugs": {
    "url": "https://github.com/cezaraugusto/browser-extension-capabilities/issues"
  },
  "homepage": "https://github.com/cezaraugusto/browser-extension-capabilities#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@rslib/core": "^0.9.2",
    "@types/node": "^22.15.30",
    "eslint": "^10.5.0",
    "eslint-config-auditor": "^2.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  },
  "publishConfig": {
    "provenance": true
  }
}
