{
  "name": "browser-extension-capabilities",
  "description": "Zero-dependency library for analyzing browser extension capabilities from manifest files",
  "packageManager": "pnpm@9.9.0",
  "version": "3.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "browser-extension-capabilities": "bin/extension-capabilities.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "keywords": [
    "browser-extension",
    "manifest",
    "capabilities",
    "analysis",
    "chrome-extension",
    "firefox-extension",
    "edge-extension",
    "webextension",
    "typescript",
    "zero-dependency"
  ],
  "author": "Cezar Augusto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cezaraugusto/browser-extension-capabilities.git"
  },
  "bugs": {
    "url": "https://github.com/cezaraugusto/browser-extension-capabilities/issues"
  },
  "homepage": "https://github.com/cezaraugusto/browser-extension-capabilities#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "data:build-compat": "node scripts/build-compat.mjs",
    "verify:compat": "node scripts/build-compat.mjs --check",
    "prepublishOnly": "npm run build",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@rslib/core": "^0.9.2",
    "@types/node": "^22.15.30",
    "eslint": "^10.5.0",
    "eslint-config-auditor": "^2.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=7.3.5",
      "vitest": ">=3.2.6",
      "rollup": ">=4.59.0",
      "minimatch": ">=9.0.7",
      "picomatch": ">=4.0.4",
      "postcss": ">=8.5.10",
      "js-yaml": ">=4.2.0",
      "brace-expansion": ">=2.0.2",
      "tmp": ">=0.2.6",
      "esbuild": ">=0.25.0"
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "sideEffects": false
}
